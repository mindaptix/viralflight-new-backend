PORT=5000
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@HOST/DATABASE

JWT_SECRET=change_this_access_token_secret
JWT_REFRESH_SECRET=change_this_refresh_token_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PAYLOAD_SECRET=change_this_payload_admin_secret

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

INSTAGRAM_APP_ID=1234567890
INSTAGRAM_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_REDIRECT_URI=http://localhost:5000/api/influencer/instagram/callback
INSTAGRAM_GRAPH_API_VERSION=v23.0
INSTAGRAM_TOKEN_ENCRYPTION_KEY=64_hex_character_key_for_aes_256_gcm_tokens
INSTAGRAM_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/dashboard/influencer
INSTAGRAM_OAUTH_ERROR_REDIRECT=http://localhost:3000/dashboard/influencer
INSTAGRAM_RECENT_MEDIA_LIMIT=12
